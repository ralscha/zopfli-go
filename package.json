{
  "name": "zopfli-go",
  "version": "1.0.0",
  "description": "JavaScript wrapper around the zopfli-go asset precompression CLI",
  "main": "./npm/index.js",
  "types": "./npm/index.d.ts",
  "exports": {
    ".": {
      "types": "./npm/index.d.ts",
      "require": "./npm/index.js"
    }
  },
  "bin": {
    "zopfli-go": "./npm/bin/zopfli-go.js"
  },
  "files": [
    "npm/index.js",
    "npm/index.d.ts",
    "npm/bin",
    "npm/lib",
    "npm/scripts",
    "package.json"
  ],
  "scripts": {
    "test:js": "node --test npm/**/*.test.js",
    "postinstall": "node ./npm/scripts/postinstall.js"
  },
  "engines": {
    "node": ">=24"
  },
  "zopfliGo": {
    "owner": "ralscha",
    "repo": "zopfli-go",
    "binaryName": "zopfli-go",
    "tagPrefix": "v",
    "assetNameTemplate": "{{binary}}_{{version}}_{{os}}_{{arch}}{{extension}}"
  }
}